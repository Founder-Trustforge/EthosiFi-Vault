<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EthosiFi Hub — The Security-First Crypto Community</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Syne:wght@400;600;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #020818;
    --navy2: #050f2a;
    --cyan: #00d4ff;
    --cyan2: #00ffea;
    --electric: #0088ff;
    --gold: #ffd700;
    --red: #ff3355;
    --green: #00ff88;
    --purple: #8855ff;
    --white: #f0f8ff;
    --muted: #5a7a9a;
    --card: rgba(5, 20, 50, 0.7);
    --border: rgba(0, 212, 255, 0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'Syne', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 12px; height: 12px;
    background: var(--cyan);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s, width 0.2s, height 0.2s, opacity 0.2s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1px solid rgba(0,212,255,0.4);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99998;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease, width 0.3s, height 0.3s;
  }

  /* Animated grid background */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  /* Nebula orbs */
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    animation: orbFloat 12s ease-in-out infinite;
  }
  .orb1 { width: 600px; height: 600px; background: rgba(0,136,255,0.08); top: -200px; right: -100px; animation-delay: 0s; }
  .orb2 { width: 400px; height: 400px; background: rgba(0,255,234,0.06); bottom: 100px; left: -150px; animation-delay: -4s; }
  .orb3 { width: 300px; height: 300px; background: rgba(136,85,255,0.07); top: 40%; right: 20%; animation-delay: -8s; }

  @keyframes orbFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-40px) scale(1.05); }
  }

  /* Scanline overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 1;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(2, 8, 24, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-size: 20px;
    font-weight: 900;
    color: var(--cyan);
    letter-spacing: 2px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo .shield {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, var(--cyan), var(--electric));
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cyan); }

  .nav-cta {
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    padding: 8px 20px;
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    cursor: none;
    transition: all 0.2s;
    text-decoration: none;
  }
  .nav-cta:hover {
    background: var(--cyan);
    color: var(--navy);
  }

  /* HERO */
  .hero {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
  }

  .hero-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(40px, 7vw, 88px);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 8px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.4s forwards;
  }

  .hero-title .line1 { color: var(--white); display: block; }
  .hero-title .line2 {
    display: block;
    background: linear-gradient(90deg, var(--cyan), var(--cyan2), var(--electric));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    max-width: 600px;
    line-height: 1.7;
    margin: 24px auto 48px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.6s forwards;
  }

  .hero-stats {
    display: flex;
    gap: 48px;
    justify-content: center;
    margin-bottom: 64px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.8s forwards;
  }

  .stat {
    text-align: center;
  }
  .stat-val {
    font-family: 'Orbitron', monospace;
    font-size: 28px;
    font-weight: 700;
    color: var(--cyan);
    display: block;
  }
  .stat-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
    display: block;
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: fadeUp 0.8s ease 1.2s forwards;
  }
  .hero-scroll span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(var(--cyan), transparent);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* SECTION LABEL */
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 4px;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    text-align: center;
    margin-bottom: 16px;
    color: var(--white);
  }

  .section-sub {
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    max-width: 560px;
    margin: 0 auto 64px;
    line-height: 1.7;
  }

  /* HUB TILES */
  .hub-section {
    position: relative;
    z-index: 2;
    padding: 100px 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .tiles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 20px;
  }

  /* Featured large tiles */
  .tile:nth-child(1) { grid-column: span 2; grid-row: span 1; }
  .tile:nth-child(2) { grid-column: span 2; grid-row: span 1; }
  .tile:nth-child(7) { grid-column: span 2; }
  .tile:nth-child(8) { grid-column: span 2; }

  .tile {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 36px;
    overflow: hidden;
    cursor: none;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,212,255,0.05), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tile:hover {
    transform: translateY(-6px);
    border-color: rgba(0,212,255,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px rgba(0,212,255,0.1);
  }

  .tile:hover::before { opacity: 1; }

  .tile-accent {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
  }

  .tile-icon {
    font-size: 36px;
    margin-bottom: 20px;
    display: block;
  }

  .tile-num {
    position: absolute;
    top: 20px; right: 24px;
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--border);
    letter-spacing: 2px;
  }

  .tile-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }

  .tile-title {
    font-family: 'Orbitron', monospace;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white);
    line-height: 1.3;
  }

  .tile-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }

  .tile-arrow {
    position: absolute;
    bottom: 28px; right: 28px;
    width: 32px; height: 32px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: all 0.3s;
    color: var(--muted);
  }

  .tile:hover .tile-arrow {
    border-color: var(--cyan);
    color: var(--cyan);
    background: rgba(0,212,255,0.1);
  }

  /* BG glow inside tiles */
  .tile-glow {
    position: absolute;
    width: 200px; height: 200px;
    border-radius: 50%;
    filter: blur(60px);
    bottom: -60px; right: -60px;
    opacity: 0.15;
    pointer-events: none;
  }

  /* TICKER BAR */
  .ticker-bar {
    position: relative;
    z-index: 2;
    background: rgba(0,212,255,0.05);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 12px 0;
    overflow: hidden;
  }

  .ticker-track {
    display: flex;
    gap: 48px;
    animation: ticker 30s linear infinite;
    white-space: nowrap;
  }

  .ticker-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ticker-item .up { color: var(--green); }
  .ticker-item .down { color: var(--red); }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ALERT BANNER */
  .alert-banner {
    position: relative;
    z-index: 2;
    margin: 0 40px;
    background: rgba(255, 51, 85, 0.08);
    border: 1px solid rgba(255, 51, 85, 0.3);
    padding: 16px 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
  }

  .alert-dot {
    width: 8px; height: 8px;
    background: var(--red);
    border-radius: 50%;
    animation: blink 1.5s ease infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--red); }
    50% { opacity: 0.3; box-shadow: none; }
  }

  .alert-label {
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    color: var(--red);
    letter-spacing: 3px;
    flex-shrink: 0;
  }

  .alert-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: rgba(255,51,85,0.8);
  }

  /* AI DEMAND SECTION */
  .demand-section {
    position: relative;
    z-index: 2;
    padding: 100px 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .demand-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .demand-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 40px;
  }

  .demand-bar {
    margin-bottom: 20px;
  }

  .demand-bar-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .demand-bar-label {
    font-size: 13px;
    color: var(--white);
    font-weight: 600;
  }

  .demand-bar-pct {
    font-family: 'Orbitron', monospace;
    font-size: 13px;
    font-weight: 700;
  }

  .demand-bar-track {
    height: 6px;
    background: rgba(255,255,255,0.05);
    overflow: hidden;
  }

  .demand-bar-fill {
    height: 100%;
    border-radius: 0;
    transition: width 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .demand-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* SUBMIT FORM */
  .submit-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-input, .form-textarea {
    background: rgba(0,212,255,0.03);
    border: 1px solid var(--border);
    color: var(--white);
    padding: 14px 18px;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }

  .form-input:focus, .form-textarea:focus {
    border-color: rgba(0,212,255,0.5);
  }

  .form-input::placeholder, .form-textarea::placeholder {
    color: var(--muted);
  }

  .form-btn {
    background: linear-gradient(90deg, var(--cyan), var(--electric));
    border: none;
    color: var(--navy);
    padding: 16px 32px;
    font-family: 'Orbitron', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    cursor: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .form-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* SCAM SECTION */
  .scam-section {
    position: relative;
    z-index: 2;
    padding: 100px 40px;
    background: rgba(255,51,85,0.03);
    border-top: 1px solid rgba(255,51,85,0.1);
    border-bottom: 1px solid rgba(255,51,85,0.1);
  }

  .scam-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .report-agencies {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 40px;
  }

  .agency-card {
    background: rgba(255,51,85,0.05);
    border: 1px solid rgba(255,51,85,0.2);
    padding: 24px;
    transition: border-color 0.2s, transform 0.2s;
    cursor: none;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .agency-card:hover {
    border-color: rgba(255,51,85,0.5);
    transform: translateY(-4px);
  }

  .agency-name {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--red);
    margin-bottom: 6px;
  }

  .agency-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .agency-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: rgba(255,51,85,0.6);
    margin-top: 10px;
    display: block;
  }

  /* FOOTER */
  footer {
    position: relative;
    z-index: 2;
    padding: 60px 40px 40px;
    border-top: 1px solid var(--border);
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand {
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 900;
    color: var(--cyan);
    margin-bottom: 16px;
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-col h4 {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--white); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  .footer-vault-link {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--cyan);
    text-decoration: none;
    letter-spacing: 2px;
    border: 1px solid var(--border);
    padding: 8px 16px;
    transition: all 0.2s;
  }

  .footer-vault-link:hover {
    border-color: var(--cyan);
    background: rgba(0,212,255,0.05);
  }

  /* FAUCET MINI */
  .faucet-widget {
    background: rgba(0,255,136,0.04);
    border: 1px solid rgba(0,255,136,0.15);
    padding: 32px;
    margin-top: 40px;
  }

  .faucet-title {
    font-family: 'Orbitron', monospace;
    font-size: 16px;
    color: var(--green);
    margin-bottom: 8px;
  }

  .faucet-sub {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .faucet-row {
    display: flex;
    gap: 12px;
  }

  .faucet-input {
    flex: 1;
    background: rgba(0,255,136,0.03);
    border: 1px solid rgba(0,255,136,0.15);
    color: var(--white);
    padding: 12px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    outline: none;
  }

  .faucet-btn {
    background: rgba(0,255,136,0.15);
    border: 1px solid var(--green);
    color: var(--green);
    padding: 12px 24px;
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    cursor: none;
    transition: all 0.2s;
  }

  .faucet-btn:hover {
    background: rgba(0,255,136,0.25);
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div class="grid-bg"></div>
<div class="orb orb1"></div>
<div class="orb orb2"></div>
<div class="orb orb3"></div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">
    <div class="shield">⬡</div>
    ETHOSIFI HUB
  </a>
  <ul class="nav-links">
    <li><a href="#hub">Community</a></li>
    <li><a href="#scam">Scam Report</a></li>
    <li><a href="#builders">Builders</a></li>
    <li><a href="#demand">Demands</a></li>
    <li><a href="#investors">Investors</a></li>
  </ul>
  <a href="https://ethosifi.com" class="nav-cta">LAUNCH VAULT →</a>
</nav>

<!-- TICKER -->
<div class="ticker-bar" style="margin-top:64px">
  <div class="ticker-track" id="ticker">
    <span class="ticker-item">BTC <span class="up">▲ $84,220</span></span>
    <span class="ticker-item">ETH <span class="up">▲ $3,840</span></span>
    <span class="ticker-item">SOL <span class="down">▼ $152.40</span></span>
    <span class="ticker-item">MATIC <span class="up">▲ $0.92</span></span>
    <span class="ticker-item">LINK <span class="up">▲ $18.44</span></span>
    <span class="ticker-item">ARB <span class="down">▼ $1.12</span></span>
